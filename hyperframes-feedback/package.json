{
  "name": "hyperframes-feedback",
  "version": "0.1.0",
  "private": true,
  "main": "dist/extension.js",
  "description": "Ableton Live Extension: render deterministic, music-locked MP4s and AI project reviews via HyperFrames",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "build:ext": "node tools/build-extension.mjs",
    "package:ext": "node tools/build-extension.mjs --production && extensions-cli package -o dist/hyperframes-feedback.ablx -i templates .",
    "run:ext": "npm run build:ext && extensions-cli run"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:../../extensions-sdk-1.0.0-beta.0/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@ableton-extensions/sdk": "file:../../extensions-sdk-1.0.0-beta.0/ableton-extensions-sdk-1.0.0-beta.0.tgz",
    "@types/node": "^24.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "abort-controller": "^3.0.0",
    "event-target-shim": "^6.0.2",
    "undici": "^8.7.0"
  }
}
