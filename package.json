{
  "name": "clip2video",
  "version": "0.1.0",
  "private": true,
  "description": "Ableton Live Extension: render deterministic, music-locked MP4s via HyperFrames",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:template-lib": "esbuild src/timebridge.ts --bundle --format=iife --global-name=TimeBridgeLib --outfile=templates/pulse-waveform/timebridge.browser.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
