{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/clip2video/timeline.schema.json",
  "title": "Clip2Video Timeline",
  "description": "Ground-truth musical timing exported from an Ableton Live Set, consumed by HyperFrames templates. All positions are in beats (quarter notes) unless noted. Beat 0 = start of the exported region. The template converts beats to seconds via the tempo map, and seconds to frames via the render fps.",
  "type": "object",
  "required": ["formatVersion", "meta", "timing", "audio", "notes", "automation", "markers", "video"],
  "properties": {
    "formatVersion": {
      "type": "string",
      "description": "Semver of this schema. Templates should check major version.",
      "examples": ["1.0.0"]
    },

    "meta": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "description": "Clip or Set name, used for on-screen titles." },
        "artist": { "type": "string" },
        "clipColor": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "The Live clip color, so visuals can inherit the producer's own color-coding."
        },
        "liveVersion": { "type": "string", "examples": ["12.4.5"] },
        "extensionVersion": { "type": "string" },
        "exportedAt": { "type": "string", "format": "date-time" },
        "sourceScope": {
          "type": "string",
          "enum": ["clip", "track", "arrangement"],
          "description": "What was right-clicked to produce this export."
        }
      }
    },

    "timing": {
      "type": "object",
      "required": ["durationBeats", "tempoMap", "timeSignatures"],
      "properties": {
        "durationBeats": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Total length of the exported region in beats."
        },
        "tempoMap": {
          "type": "array",
          "minItems": 1,
          "description": "Sorted by beat. A single entry means constant tempo. Linear ramps between entries when `ramp` is true on the earlier entry; otherwise tempo holds until the next entry (Live-style tempo automation supports both).",
          "items": {
            "type": "object",
            "required": ["beat", "bpm"],
            "properties": {
              "beat": { "type": "number", "minimum": 0 },
              "bpm": { "type": "number", "exclusiveMinimum": 0 },
              "ramp": { "type": "boolean", "default": false }
            }
          }
        },
        "timeSignatures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["beat", "numerator", "denominator"],
            "properties": {
              "beat": { "type": "number", "minimum": 0 },
              "numerator": { "type": "integer", "minimum": 1 },
              "denominator": { "type": "integer", "enum": [1, 2, 4, 8, 16, 32] }
            }
          }
        }
      }
    },

    "audio": {
      "type": "object",
      "required": ["file", "durationSeconds"],
      "properties": {
        "file": {
          "type": "string",
          "description": "Path or URL of the bounced audio, relative to this JSON file.",
          "examples": ["audio.wav"]
        },
        "sampleRate": { "type": "integer", "examples": [44100, 48000] },
        "channels": { "type": "integer", "minimum": 1 },
        "durationSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "offsetBeats": {
          "type": "number",
          "default": 0,
          "description": "If the audio starts before beat 0 (e.g. reverb pre-roll), the offset in beats."
        }
      }
    },

    "notes": {
      "type": "array",
      "description": "All MIDI notes in the exported region, sorted by startBeat. Empty for audio-only exports.",
      "items": {
        "type": "object",
        "required": ["pitch", "startBeat", "lengthBeats", "velocity"],
        "properties": {
          "pitch": { "type": "integer", "minimum": 0, "maximum": 127 },
          "startBeat": { "type": "number", "minimum": 0 },
          "lengthBeats": { "type": "number", "exclusiveMinimum": 0 },
          "velocity": { "type": "integer", "minimum": 1, "maximum": 127 },
          "muted": { "type": "boolean", "default": false },
          "probability": { "type": "number", "minimum": 0, "maximum": 1 },
          "trackId": { "type": "string", "description": "Present for track/arrangement scope exports." }
        }
      }
    },

    "automation": {
      "type": "object",
      "description": "Map of laneId -> sampled automation lane. Lane IDs are stable slugs like 'track1.filter_cutoff'.",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "min", "max", "points"],
        "properties": {
          "name": { "type": "string", "description": "Human-readable, e.g. 'Auto Filter > Frequency'." },
          "unit": { "type": "string", "examples": ["Hz", "dB", "%"] },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "points": {
            "type": "array",
            "minItems": 1,
            "description": "Breakpoints sorted by beat. Templates interpolate between them.",
            "items": {
              "type": "object",
              "required": ["beat", "value"],
              "properties": {
                "beat": { "type": "number", "minimum": 0 },
                "value": { "type": "number", "description": "Raw parameter value in [min, max]." },
                "curve": {
                  "type": "string",
                  "enum": ["linear", "hold", "sCurve"],
                  "default": "linear",
                  "description": "Shape from this point to the next."
                }
              }
            }
          }
        }
      }
    },

    "markers": {
      "type": "array",
      "description": "Arrangement locators / section markers, sorted by beat.",
      "items": {
        "type": "object",
        "required": ["beat", "label"],
        "properties": {
          "beat": { "type": "number", "minimum": 0 },
          "label": { "type": "string", "examples": ["Intro", "Drop"] },
          "kind": { "type": "string", "enum": ["section", "cue"], "default": "section" }
        }
      }
    },

    "tracks": {
      "type": "array",
      "description": "Present for track/arrangement scope, so templates can label and color stems.",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "kind": { "type": "string", "enum": ["midi", "audio", "return", "master", "group"] }
        }
      }
    },

    "video": {
      "type": "object",
      "required": ["width", "height", "fps", "style"],
      "properties": {
        "width": { "type": "integer", "examples": [1080] },
        "height": { "type": "integer", "examples": [1920] },
        "fps": { "type": "integer", "enum": [24, 25, 30, 50, 60], "default": 30 },
        "style": { "type": "string", "description": "Template folder name.", "examples": ["pulse-waveform"] },
        "mappings": {
          "type": "array",
          "description": "The VJ layer: routes an automation lane to a visual parameter exposed by the template.",
          "items": {
            "type": "object",
            "required": ["lane", "target"],
            "properties": {
              "lane": { "type": "string", "description": "Key into `automation`." },
              "target": {
                "type": "string",
                "description": "Template-defined visual parameter, e.g. 'glow', 'zoom', 'hueShift'."
              },
              "invert": { "type": "boolean", "default": false },
              "range": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2,
                "description": "Output range after normalization, default [0,1]."
              }
            }
          }
        }
      }
    }
  }
}
